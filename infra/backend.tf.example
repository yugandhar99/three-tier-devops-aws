# Example remote state backend.
# Copy to backend.tf and update values for your AWS account before using in real deployments.

terraform {
  backend "s3" {
    bucket         = "REPLACE_WITH_TERRAFORM_STATE_BUCKET"
    key            = "three-tier-devops-aws/terraform.tfstate"
    region         = "us-west-2"
    encrypt        = true
    dynamodb_table = "REPLACE_WITH_TERRAFORM_LOCK_TABLE"
  }
}
